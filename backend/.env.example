PORT=3000
JWT_SECRET=change-me-long-random-string
REGISTER_SECRET=change-me-invite-bootstrap-code
TRUST_PROXY=0
# Production behind HTTPS: set COOKIE_SECURE=1 so auth cookies are sent only over TLS
COOKIE_SECURE=0

# Donate webhook: POST /api/donate/callback with header X-Webhook-Secret
# (value from dashboard Integrations; do not put the secret in the URL)
